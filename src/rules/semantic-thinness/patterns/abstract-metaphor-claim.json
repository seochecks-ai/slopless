{
  "id": "abstract-metaphor-claim",
  "class": "abstract-metaphor",
  "purpose": "Catch slogan-like abstract metaphors where an abstract subject performs a physical or spatial action with no concrete referent.",
  "matchMode": "contains",
  "maxTokens": 42,
  "templates": [
    "{abstractSubject} {metaphorVerb} in {abstractObject}.",
    "{abstractSubject} {metaphorVerb} mostly in {abstractObject}.",
    "{abstractSubject} {metaphorVerb} inside {abstractObject}.",
    "{abstractSubject} {metaphorVerb} after {abstractObject}.",
    "{abstractSubject} {metaphorVerb} with {abstractObject}.",
    "{abstractSubject} {linkingVerb} {abstractComplement}.",
    "{artifactSubject} {metaphorVerb} its {answerNoun} to {abstractDestination}.",
    "{artifactSubject} {linkingVerb} wearing a {surfaceNoun} over an {emptyNoun}.",
    "{artifactSubject} {metaphorVerb} like a {humanRole} after a {vagueEvent}.",
    "{abstractSubject} {linkingVerb} {infrastructureNoun} with {abstractObject}.",
    "{abstractSubject} behaves like a {filterNoun}.",
    "{artifactSubject} adds another {layerNoun} to {diagnosisObject}.",
    "{artifactSubject} add another {layerNoun} to {diagnosisObject}."
  ],
  "slots": {
    "abstractSubject": [
      "ai visibility",
      "ai assistants",
      "average rank",
      "crawler access",
      "prevention",
      "problem-solving",
      "trust",
      "clarity",
      "repair",
      "growth",
      "change",
      "resilience",
      "confidence",
      "connection",
      "discipline",
      "leadership",
      "healing",
      "progress",
      "safety",
      "accountability",
      "momentum",
      "consistency",
      "daily life",
      "the answer",
      "the brand",
      "the page",
      "the work",
      "the lesson",
      "the process",
      "the practice",
      "the relationship"
    ],
    "metaphorVerb": [
      "lives",
      "lands",
      "sits",
      "starts",
      "belongs",
      "rests",
      "moves",
      "breathes",
      "travels",
      "vanishes",
      "disappears",
      "outsources",
      "cannot outsource",
      "can't outsource",
      "arrives",
      "settles",
      "grows",
      "shows up",
      "takes root",
      "holds"
    ],
    "artifactSubject": [
      "ai overviews",
      "content",
      "structured data",
      "the answer",
      "the brand",
      "the business",
      "the page",
      "the post",
      "the report",
      "visibility"
    ],
    "abstractObject": [
      "consequences",
      "diagnosis",
      "rehearsal",
      "repair",
      "practice",
      "consistency",
      "attention",
      "patience",
      "discipline",
      "the work",
      "the process",
      "the lesson",
      "the moment",
      "the pattern",
      "the relationship",
      "the conversation",
      "the storm",
      "the quiet",
      "the rhythm",
      "metadata"
    ],
    "linkingVerb": ["is", "was", "becomes", "became", "remains"],
    "abstractComplement": [
      "a steadier rhythm",
      "a quieter practice",
      "a different kind of repair",
      "a form of rehearsal",
      "a kind of discipline",
      "a daily practice",
      "the real curriculum",
      "the actual work"
    ],
    "answerNoun": [
      "answer",
      "explanation",
      "job",
      "meaning",
      "proof",
      "substance"
    ],
    "abstractDestination": [
      "metadata",
      "schema",
      "the plugin panel",
      "the spreadsheet",
      "the dashboard",
      "the tool"
    ],
    "surfaceNoun": [
      "clean jacket",
      "fancy jacket",
      "nice jacket",
      "sharp jacket",
      "polished jacket"
    ],
    "emptyNoun": [
      "empty shirt",
      "empty body",
      "empty page",
      "empty shell",
      "hollow shell"
    ],
    "humanRole": ["contractor", "consultant", "vendor", "agency", "freelancer"],
    "vagueEvent": [
      "vague scope call",
      "vague kickoff",
      "bad kickoff",
      "loose briefing",
      "messy handoff"
    ],
    "infrastructureNoun": ["plumbing", "machinery", "scaffolding"],
    "filterNoun": [
      "trust filter",
      "qualification filter",
      "credibility filter",
      "source filter"
    ],
    "layerNoun": ["layer", "dimension", "surface"],
    "diagnosisObject": [
      "the diagnosis",
      "the report",
      "the audit",
      "the decision",
      "the analysis"
    ]
  },
  "rejectIf": [
    "subject is concrete or named",
    "verb use is literal",
    "sentence includes a concrete example, event, actor, object, number, date, or causal explanation",
    "metaphor is inside quoted literary prose"
  ],
  "positiveExamples": [
    "Prevention lives in rehearsal.",
    "Problem-solving lands after the storm.",
    "Trust sits inside repair.",
    "The answer is a steadier rhythm.",
    "Daily life is the curriculum.",
    "Safety starts with consistency."
  ],
  "negativeExamples": [
    "The backup generator sits inside the repair shop.",
    "The answer is to move the server restart before the migration.",
    "Prevention starts with installing smoke alarms in every bedroom.",
    "Trust improved after the team published the missing incident timeline."
  ],
  "notes": [
    "This pattern needs abstract/concrete slot checks before activation.",
    "Short slogan-like sentences are higher confidence than long explanatory sentences."
  ]
}
